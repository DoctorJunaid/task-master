<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | TaskMaster</title>

    <link rel="stylesheet" href="/css/auth.css">
    <link rel="stylesheet" href="/css/header.css">
    <link rel="stylesheet" href="/css/footer.css">
    <link rel="stylesheet" href="/css/dashboard.css">

    <% if (!user) { %>
        <script>
            window.location.href = '/login';
        </script>
    <% } %>
</head>
<body>

    <%- include('partials/header') %>

    <main class="dashboard-container">

        <section class="welcome-banner">
            <div class="welcome-text">
                <h1>Hello, <%= user ? (user.username || 'User') : 'User' %></h1>
                <% const pendingTasks = todo.filter(t => t.isDone === false); %>
                <p id="pendingTasksText">
                    You have <strong id="pendingTasksCount"><%= pendingTasks.length %></strong> tasks pending today.
                </p>
            </div>
            <button class="add-task-btn" id="openModalBtn">
                <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
                Create Task
            </button>
        </section>

        <section class="controls-bar">
            <div class="search-box">
                <svg class="search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
                <input type="text" class="search-input" placeholder="Search your tasks...">
            </div>

            <div class="filter-group">
                <button class="filter-btn active" data-filter="all">All</button>
                <button class="filter-btn" data-filter="pending">Pending</button>
                <button class="filter-btn" data-filter="completed">Done</button>
            </div>
        </section>

        <section class="task-grid" id="taskGrid">
            <% if (todo && todo.length > 0) { %>
                <% todo.forEach(task => { %>
                    <div class="task-card" data-id="<%= task.id %>" data-status="<%= task.isDone ? 'completed' : 'pending' %>" style="<%= task.isDone ? 'opacity: 0.5;' : '' %>">
                        <div class="task-header">
                            <h3 class="task-title"><%= task.todoName %></h3>
                        </div>
                        <p class="task-desc"><%= task.todoDescription || 'No description provided.' %></p>
                        <div class="task-footer">
                            <div class="date-badge">
                                <svg class="date-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
                                <span><%= task.dueDate ? new Date(task.dueDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) : 'No date' %></span>
                            </div>

                            <label class="check-container">
                                <input type="checkbox" name="status" <%= task.isDone ? 'checked' : '' %> onchange="toggleTaskStatus(this, '<%= task.id %>')">
                                <span class="checkmark" title="Mark as Done">
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                                </span>
                            </label>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div style="grid-column: 1/-1; text-align: center; padding: 2rem; color: #666;">
                    <p>No tasks yet. Create your first task!</p>
                </div>
            <% } %>
        </section>

    </main>

    <%- include('partials/footer') %>

    <div class="modal-overlay" id="taskModal">
        <div class="modal-card">
            <div class="modal-header">
                <h2>New Task</h2>
                <button class="close-modal" id="closeModalBtn">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
                </button>
            </div>

            <form id="createTaskForm">
                <div class="input-group">
                    <input type="text" name="title" class="input-field" placeholder="What needs to be done?" required>
                </div>

                <div class="input-group">
                    <input type="text" name="description" class="input-field" placeholder="Description (Optional)">
                </div>

                <div class="input-group">
                    <input type="date" name="duedate" class="input-field" required>
                </div>

                <button type="submit" class="submit-btn">Create Task</button>
            </form>
        </div>
    </div>

    <script src="/js/header.js"></script>
    <script>
        // --- Modal Logic ---
        const modal = document.getElementById('taskModal');
        const openBtn = document.getElementById('openModalBtn');
        const closeBtn = document.getElementById('closeModalBtn');

        openBtn.addEventListener('click', () => modal.classList.add('open'));
        closeBtn.addEventListener('click', () => modal.classList.remove('open'));
        modal.addEventListener('click', (e) => { if (e.target === modal) modal.classList.remove('open'); });

        // --- Create Task Form Submission ---
        const createTaskForm = document.getElementById('createTaskForm');
        createTaskForm.addEventListener('submit', async (e) => {
            e.preventDefault();

            const formData = new FormData(createTaskForm);
            const taskData = {
                todoName: formData.get('title'),
                todoDescription: formData.get('description'),
                dueDate: formData.get('duedate')
            };

            try {
                const response = await fetch('/api/users/<%= user.username %>/todo', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    credentials: 'include',
                    body: JSON.stringify(taskData)
                });

                if (response.ok) {
                    // Close modal and reload page
                    modal.classList.remove('open');
                    createTaskForm.reset();
                    window.location.reload();
                } else {
                    const error = await response.json();
                    alert('Failed to create task: ' + (error.msg || 'Unknown error'));
                }
            } catch (error) {
                console.error('Error creating task:', error);
                alert('Failed to create task. Please try again.');
            }
        });

        // --- Toggle Task Status ---
        async function toggleTaskStatus(checkbox, taskId) {
            const card = checkbox.closest('.task-card');
            const newStatus = checkbox.checked;

            try {
                const response = await fetch(`/api/users/<%= user.username %>/todo/${taskId}/status`, {
                    method: 'PATCH',
                    headers: {
                        'Content-Type': 'application/json',
                    },
                    credentials: 'include',
                    body: JSON.stringify({ status: newStatus })
                });

                if (response.ok) {
                    // Update card appearance
                    card.style.opacity = newStatus ? '0.5' : '1';
                    card.setAttribute('data-status', newStatus ? 'completed' : 'pending');

                    // Update pending tasks count in real-time
                    updatePendingCount();
                } else {
                    // Revert checkbox if update failed
                    checkbox.checked = !newStatus;
                    alert('Failed to update task status');
                }
            } catch (error) {
                console.error('Error updating task status:', error);
                checkbox.checked = !newStatus;
                alert('Failed to update task status. Please try again.');
            }
        }

        // --- Update Pending Tasks Count ---
        function updatePendingCount() {
            const allCards = document.querySelectorAll('.task-card');
            let pendingCount = 0;

            allCards.forEach(card => {
                const status = card.getAttribute('data-status');
                if (status === 'pending') {
                    pendingCount++;
                }
            });

            const countElement = document.getElementById('pendingTasksCount');
            if (countElement) {
                countElement.textContent = pendingCount;
            }
        }

        // --- Filter Tasks ---
        const filterBtns = document.querySelectorAll('.filter-btn');
        const taskCards = document.querySelectorAll('.task-card');

        filterBtns.forEach(btn => {
            btn.addEventListener('click', () => {
                // Update active button
                filterBtns.forEach(b => b.classList.remove('active'));
                btn.classList.add('active');

                const filter = btn.getAttribute('data-filter');

                taskCards.forEach(card => {
                    const status = card.getAttribute('data-status');

                    if (filter === 'all') {
                        card.style.display = 'block';
                    } else if (filter === 'pending' && status === 'pending') {
                        card.style.display = 'block';
                    } else if (filter === 'completed' && status === 'completed') {
                        card.style.display = 'block';
                    } else {
                        card.style.display = 'none';
                    }
                });
            });
        });

        // --- Search Tasks ---
        const searchInput = document.querySelector('.search-input');
        searchInput.addEventListener('input', (e) => {
            const searchTerm = e.target.value.toLowerCase();

            taskCards.forEach(card => {
                const title = card.querySelector('.task-title').textContent.toLowerCase();
                const desc = card.querySelector('.task-desc').textContent.toLowerCase();

                if (title.includes(searchTerm) || desc.includes(searchTerm)) {
                    card.style.display = 'block';
                } else {
                    card.style.display = 'none';
                }
            });
        });
    </script>
</body>
</html>

